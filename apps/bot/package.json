{
	"name": "@jordan-devs/bot",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=22.0"
	},
	"main": "dist/index.js",
	"scripts": {
		"start": "node dist/index.js",
		"dev": "tsx --watch index.ts",
		"build": "tsc -p tsconfig.json",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"lint": "tsc --noEmit -p tsconfig.json",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "vitest run src/__tests__/e2e/command-dispatch.test.ts",
		"test:phase1": "tsx src/ProductionIncident/testing/phase1/phase1-smoke.test.ts"
	},
	"dependencies": {
		"@ai-sdk/google": "^4.0.12",
		"@jordan-devs/ai": "workspace:*",
		"@jordan-devs/config": "workspace:*",
		"@octokit/rest": "^22.0.1",
		"ai": "^6.0.105",
		"ai-sdk-provider-opencode-sdk": "^3.0.6",
		"chalk": "^5.6.2",
		"change-case": "^5.4.4",
		"colord": "^2.9.3",
		"commandkit": "github:AboMeezO/DevRoots-Commandkit#2f2dd30dfe2d88bed821519f35869f6ffac14ece",
		"discord.js": "^14.26.4",
		"fastest-levenshtein": "^1.0.16",
		"ipaddr.js": "^2.4.0",
		"jose": "^6.2.3",
		"ms": "^2.1.3",
		"safe-regex2": "^5.1.1",
		"slugify": "^1.6.9",
		"tldts": "^7.4.3",
		"whoiser": "2.0.0-beta.10",
		"zod": "^4.4.3"
	},
	"imports": {
		"#Database": "./dist/src/Database/index.js",
		"#ChatCommands": "./dist/src/ChatCommands/index.js",
		"#Config": "./dist/src/config.js",
		"#AuditLog": "./dist/src/audit-log.js",
		"#Logger": "./dist/src/Logger/index.js",
		"#ComponentsV2": "./dist/src/ComponentsV2/index.js",
		"#EmojiRegistry": "./dist/src/EmojiRegistry/index.js",
		"#Assets": "./Assets/"
	},
	"devDependencies": {
		"@types/ms": "^2.1.0",
		"typescript": "^5.7.0",
		"vitest": "^4.1.9"
	}
}
