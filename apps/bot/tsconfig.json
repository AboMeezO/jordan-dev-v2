{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2022"],
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,
		"skipLibCheck": true,
		"outDir": "./dist",
		"rootDir": ".",
		"baseUrl": ".",
		"paths": {
			"#Utilities": ["src/Utilities/index.ts"],
			"#Database": ["src/Database/index.ts"],
			"#ChatCommands": ["src/ChatCommands/index.ts"],
			"#Config": ["src/config.ts"],
			"#AuditLog": ["src/audit-log.ts"],
			"#Logger": ["src/Logger/index.ts"],
			"#ComponentsV2": ["src/ComponentsV2/index.ts"],
			"#EmojiRegistry": ["src/EmojiRegistry/index.ts"],
			"#Assets": ["Assets/"]
		}
	},
	"include": ["src", "index.ts"]
}
