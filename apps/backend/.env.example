# Backend config overrides (via @jd/config path notation)
# These override values in Config.yaml at runtime.
# Required:
CLERK.SECRET_KEY=
CLERK.JWT_KEY=
DATABASE.URL=postgresql://postgres:postgres@localhost:5432/jordan_devs

# Optional:
SERVER.PORT=3001
SERVER.NODE_ENV=development
SERVER.FRONTEND_ORIGINS=http://localhost:3000
CLERK.AUTHORIZED_PARTIES=http://localhost:3000
INITIAL_ADMIN_CLERK_USER_ID=user_
