generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String                     @id @default(cuid())
  clerkUserId        String?                    @unique @map("clerk_user_id")
  discordUserId      String?                    @unique @map("discord_user_id")
  email              String?
  displayName        String?                    @map("display_name")
  avatarUrl          String?                    @map("avatar_url")
  createdAt          DateTime                   @default(now()) @map("created_at")
  updatedAt          DateTime                   @updatedAt @map("updated_at")
  roles              UserRole[]
  verifications      Verification[]
  verificationEvents VerificationEvent[]
  roleGrantJobs      VerificationRoleGrantJob[]
  applications       MembershipApplication[]

  @@map("users")
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  permissions RolePermission[]
  users       UserRole[]

  @@map("roles")
}

model Permission {
  id          String           @id
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  roleLinks   RolePermission[]

  @@map("permissions")
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

enum VerificationStatus {
  PENDING
  VERIFIED
  FAILED
  ROLE_GRANT_PENDING
  ROLE_GRANT_FAILED
}

enum VerificationEventType {
  STARTED
  COMPLETED
  FAILED
  ROLE_GRANT_PENDING
  ROLE_GRANT_COMPLETED
  ROLE_GRANT_FAILED
}

enum RoleGrantJobStatus {
  PENDING
  COMPLETED
  FAILED
}

model Verification {
  id            String                     @id @default(cuid())
  userId        String                     @map("user_id")
  discordUserId String                     @map("discord_user_id")
  guildId       String                     @map("guild_id")
  status        VerificationStatus         @default(PENDING)
  verifiedAt    DateTime?                  @map("verified_at")
  failureReason String?                    @map("failure_reason")
  createdAt     DateTime                   @default(now()) @map("created_at")
  updatedAt     DateTime                   @updatedAt @map("updated_at")
  user          User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  events        VerificationEvent[]
  roleGrantJobs VerificationRoleGrantJob[]

  @@unique([userId, guildId])
  @@index([discordUserId])
  @@index([guildId])
  @@index([status])
  @@map("verifications")
}

model VerificationEvent {
  id             String                @id @default(cuid())
  verificationId String                @map("verification_id")
  userId         String                @map("user_id")
  type           VerificationEventType
  status         VerificationStatus
  message        String?
  createdAt      DateTime              @default(now()) @map("created_at")
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  verification   Verification          @relation(fields: [verificationId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId])
  @@index([verificationId])
  @@map("verification_events")
}

model VerificationRoleGrantJob {
  id            String             @id @default(cuid())
  verificationId String             @map("verification_id")
  userId        String             @map("user_id")
  discordUserId String             @map("discord_user_id")
  guildId       String             @map("guild_id")
  status        RoleGrantJobStatus @default(PENDING)
  attempts      Int                @default(0)
  lastError     String?            @map("last_error")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  verification  Verification       @relation(fields: [verificationId], references: [id], onDelete: Cascade)

  @@unique([verificationId, status])
  @@index([status])
  @@index([userId])
  @@map("verification_role_grant_jobs")
}

enum ApplicationStatus {
  DRAFTING
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum ReferralSource {
  REDDIT
  FRIEND_INVITE
  WEB_SEARCH
  GITHUB
  OTHER
}

enum ExperienceLevel {
  JUNIOR
  MID
  SENIOR
  STAFF
}

model MembershipApplication {
  id                 String            @id @default(cuid())
  userId             String            @map("user_id")
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  guildId            String            @map("guild_id")
  status             ApplicationStatus @default(DRAFTING)

  displayName        String            @map("display_name")
  githubHandle       String            @map("github_handle")
  strongestProject   String            @map("strongest_project")
  projectExplanation String            @map("project_explanation")
  techStack          String            @map("tech_stack")
  experienceLevel    ExperienceLevel   @map("experience_level")
  purposeOfJoining   String            @map("purpose_of_joining")
  selfIntroduction   String            @map("self_introduction")
  linkedInUrl        String?           @map("linked_in_url")
  portfolioUrl       String?           @map("portfolio_url")

  referralSource     ReferralSource    @map("referral_source")
  referralOtherText  String?           @map("referral_other_text")

  reviewedBy         String?           @map("reviewed_by")
  reviewedAt         DateTime?         @map("reviewed_at")
  rejectionReason    String?           @map("rejection_reason")

  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@index([guildId])
  @@map("membership_applications")
}

model GuildConfig {
  id                    String   @id @default(cuid())
  guildId               String   @unique @map("guild_id")
  unverifiedRoleId      String   @map("unverified_role_id")
  verifiedRoleId        String   @map("verified_role_id")
  reviewerRoleId        String   @map("reviewer_role_id")
  verificationChannelId String   @map("verification_channel_id")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("guild_configs")
}
