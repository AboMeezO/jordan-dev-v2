# Discord bot
TOKEN=
DEV_GUILD_ID=
PREFIX=!

# Backend
NODE_ENV=development
PORT=3001
FRONTEND_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jordan_devs

# Clerk authentication (backend/web)
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_JWT_KEY=
CLERK_AUTHORIZED_PARTIES=http://localhost:3000

# Admin bootstrap — set a Clerk user ID then run `pnpm --dir apps/backend permissions:bootstrap`
# INITIAL_ADMIN_CLERK_USER_ID=user_...

# Discord
DISCORD_VERIFIED_ROLE_ID=
VITE_API_URL=http://localhost:3001

# Bot owners & developers (comma-separated Discord user IDs)
OWNER_IDS=
DEV_IDS=

# GitHub API token for github user/repo/issue commands
GITHUB_TOKEN=

# URL scanning (optional — without this, url-scan uses local heuristics only)
VIRUSTOTAL_API_KEY=

# Scanning configuration (optional, with defaults)
SCAN_CACHE_TTL_MS=300000
SCAN_RATE_LIMIT=10
NETWORK_TIMEOUT_MS=10000
MAX_REDIRECTS=10
