{
	"name": "@jordan-devs/config",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"bin": {
		"jd-config": "./dist/cli/index.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./nest": {
			"types": "./dist/nest/index.d.ts",
			"default": "./dist/nest/index.js"
		},
		"./cli": {
			"types": "./dist/cli/index.d.ts",
			"default": "./dist/cli/index.js"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"dotenv": "^17.4.2",
		"yaml": "^2.7.0",
		"zod": "^4.2.0"
	},
	"peerDependencies": {
		"@nestjs/common": "^11.0.0",
		"@nestjs/config": "^4.0.0"
	},
	"peerDependenciesMeta": {
		"@nestjs/common": {
			"optional": true
		},
		"@nestjs/config": {
			"optional": true
		}
	},
	"devDependencies": {
		"@nestjs/common": "^11.1.28",
		"@nestjs/config": "^4.0.2",
		"@types/node": "^25.9.1",
		"typescript": "^6.0.3",
		"vitest": "^4.1.9"
	}
}
